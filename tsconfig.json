{
    "compilerOptions": {
      "skipLibCheck": true,
      "target": "ES2020",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "node",
      "jsx": "react-jsx",
      "strict": false,
      "noEmit": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "isolatedModules": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
  }